def main():
    """Main entry point"""
    # Check for no arguments or single flags
    if len(sys.argv) < 2:
        # Default behavior: show help
        print_compact_usage()
        return 0
    
    command = sys.argv[1]
    args = sys.argv[2:]
    
    # Handle context command
    if command in ["context", "co"]:
        # New multi-agent context system
        return handle_context_command(args)
    
    # Help command
    if command in ["help", "-h", "--help"]:
        # Check if we're in Claude Code environment
        in_claude_code = is_claude_code_environment()
        
        if args and args[0] == "full":
            # Always use file-based approach for better Claude Code integration
            manager = CCCManager()
            commands = Commands(manager)
            return commands.help_write_and_read("full")
        elif args and args[0] == "experimental":
            # Always use file-based approach for experimental help
            manager = CCCManager()
            commands = Commands(manager)
            return commands.help_write_and_read("experimental")
        elif args and args[0] == "all":
            # Respect environment for 'help all' too
            manager = CCCManager()
            commands = Commands(manager)
            if in_claude_code:
                return commands.help_write_and_read("all")
            else:
                return commands.help_show_paged("all")
        elif args and len(args) > 0:
            # Handle special case 'full' first (allow 'f', 'fu', 'ful', 'full')
            partial_input = args[0].lower()
            if partial_input in ["f", "fu", "ful"] or partial_input.startswith("full"):
                # Partial match for 'full'
                if in_claude_code:
                    manager = CCCManager()
                    commands = Commands(manager)
                    return commands.help_write_and_read("full")
                else:
                    manager = CCCManager()
                    commands = Commands(manager)
                    return commands.help_show_paged("full")
            
            # Define valid sections
            valid_sections = ["core", "control", "services", "context", "options", "examples", "info", "sections"]
            
            # Try to find matches for partial input
            partial = args[0].lower()
            matches = [s for s in valid_sections if s.startswith(partial)]
            
            if len(matches) == 0:
                # No matches found
                print(f"❌ Ungültige Eingabe: ccc help {args[0]}")
                print("Gültige Eingabe: ccc help [full|core|control|services|communication|options|examples]")
                return 1
            elif len(matches) == 1:
                # Unique match found - use it
                section = matches[0]
                if in_claude_code:
                    manager = CCCManager()
                    commands = Commands(manager)
                    return commands.help_write_and_read(section)
                else:
                    # In terminal: use normal print for sections
                    manager = CCCManager()
                    commands = Commands(manager)
                    return commands.help_show(section)
            elif len(matches) > 1:
                # Ambiguous - show suggestions with minimal unique prefix
                suggestions = []
                for match in matches:
                    # Find the minimal unique prefix for this match
                    unique_prefix = partial
                    for i in range(len(partial), len(match)):
                        unique_prefix = match[:i+1]
                        # Check if this prefix is unique among all matches
                        other_matches = [m for m in matches if m != match and m.startswith(unique_prefix)]
                        if not other_matches:
                            # This prefix is unique
                            break
                    # Show the unique prefix and the rest in brackets
                    rest = match[len(unique_prefix):]
                    if rest:
                        suggestions.append(f"ccc help {unique_prefix}[{rest}]")
                    else:
                        suggestions.append(f"ccc help {unique_prefix}")
                print(f"❓ Ambiguous input. Please specify:")
                for suggestion in suggestions:
                    print(f"   {suggestion}")
                return 1
            elif args[0] in valid_sections:
                # Exact match (shouldn't happen but keep for safety)
                if in_claude_code:
                    manager = CCCManager()
                    commands = Commands(manager)
                    return commands.help_write_and_read(args[0])
                else:
                    manager = CCCManager()
                    commands = Commands(manager)
                    return commands.help_show(args[0])
        else:
            # Default help (compact) - always use file-based approach
            manager = CCCManager()
            commands = Commands(manager)
            return commands.help_write_and_read("compact")
        return 0
    
    # Handle session command with subcommands
    if command == "session":
        if len(args) == 0:
            print("❌ Missing subcommand. Usage: ccc session start")
            return 1

        subcommand = args[0].lower()

        # Handle partial matching for session subcommands
        if subcommand in ["start", "sta", "st"]:
            # Check for AI instance parameter
            ai_instance = args[1] if len(args) > 1 else None
            manager = CCCManager()
            commands = Commands(manager)
            return commands.session_start(ai_instance)
        elif subcommand in ["save", "sav", "sa"]:
            # Check for AI instance parameter
            ai_instance = args[1] if len(args) > 1 else None
            manager = CCCManager()
            commands = Commands(manager)
            return commands.session_save(ai_instance)
        elif subcommand in ["end", "ende", "en", "e"]:
            # Check for AI instance parameter
            ai_instance = args[1] if len(args) > 1 else None
            manager = CCCManager()
            commands = Commands(manager)
            return commands.session_end(ai_instance)
        elif subcommand in ["manage", "man", "m"]:
            # New TypeScript session management
            manager = CCCManager()
            commands = Commands(manager)
            action = args[1] if len(args) > 1 else None
            name = args[2] if len(args) > 2 else None
            return commands.session_manage(action, name)
        else:
            print(f"❌ Unknown session subcommand: {subcommand}")
            print("Available: ccc session [start|save|end|manage]")
            return 1

    # Handle partial matching for "session" command
    if command.startswith("ses") and len(args) > 0:
        subcommand = args[0].lower()
        # Check for session subcommands
        if subcommand.startswith("sta"):
            # Check for AI instance parameter
            ai_instance = args[1] if len(args) > 1 else None
            manager = CCCManager()
            commands = Commands(manager)
            return commands.session_start(ai_instance)
        elif subcommand.startswith("sav"):
            # Check for AI instance parameter
            ai_instance = args[1] if len(args) > 1 else None
            manager = CCCManager()
            commands = Commands(manager)
            return commands.session_save(ai_instance)
        elif subcommand.startswith("end") or subcommand.startswith("en"):
            # Check for AI instance parameter
            ai_instance = args[1] if len(args) > 1 else None
            manager = CCCManager()
            commands = Commands(manager)
            return commands.session_end(ai_instance)
        elif subcommand.startswith("man") or subcommand.startswith("m"):
            # New TypeScript session management
            manager = CCCManager()
            commands = Commands(manager)
            action = args[1] if len(args) > 1 else None
            name = args[2] if len(args) > 2 else None
            return commands.session_manage(action, name)
        else:
            print(f"❌ Unknown session subcommand: {subcommand}")
            print("Available: ccc session [start|save|end|manage]")
            return 1

    # Create manager and commands
    manager = CCCManager()
    commands = Commands(manager)

    # Execute command
    try:
        if command == "status":
            service = args[0] if args else "autoinput"
            return commands.status(service)
        
        elif command == "config":
            service = args[0] if args else "autoinput"
            return commands.config(service)
        
        elif command == "start":
            service = "autoinput"
            custom_text = None
            with_monitor = False
            interval_minutes = None
            
            # Parse arguments
            remaining_args = []
            for arg in args:
                if arg in ["-m", "--monitor"]:
                    with_monitor = True
                elif arg.startswith(("-t=", "--time=")):
                    # Extract time value
                    time_str = arg.split("=", 1)[1] if "=" in arg else None
                    if time_str and time_str.isdigit():
                        interval_minutes = int(time_str)
                    else:
                        print(f"❌ Invalid time format: {arg}. Use -t=n or --time=n where n is minutes")
                        return 1
                elif arg == "--":
                    break
                else:
                    remaining_args.append(arg)
            
            # Get service name if provided
            if remaining_args and remaining_args[0] != "--":
                service = remaining_args[0]
            
            # Get custom text if provided
            if "--" in args:
                idx = args.index("--")
                custom_text = " ".join(args[idx+1:]) if idx+1 < len(args) else None
            
            # Special handling for save service
            if service == "save":
                # Check for -d/--dialog option
                with_dialog = "-d" in args or "--dialog" in args
                return commands.start_save(service, with_dialog)
            else:
                return commands.start(service, custom_text, with_monitor, interval_minutes)
        
        elif command == "restart":
            service = "autoinput"
            custom_text = None
            with_monitor = False
            interval_minutes = None
            
            # Parse arguments (same as start)
            remaining_args = []
            for arg in args:
                if arg in ["-m", "--monitor"]:
                    with_monitor = True
                elif arg.startswith(("-t=", "--time=")):
                    # Extract time value
                    time_str = arg.split("=", 1)[1] if "=" in arg else None
                    if time_str and time_str.isdigit():
                        interval_minutes = int(time_str)
                    else:
                        print(f"❌ Invalid time format: {arg}. Use -t=n or --time=n where n is minutes")
                        return 1
                elif arg == "--":
                    break
                else:
                    remaining_args.append(arg)
            
            # Get service name if provided
            if remaining_args and remaining_args[0] != "--":
                service = remaining_args[0]
            
            # Get custom text if provided
            if "--" in args:
                idx = args.index("--")
                custom_text = " ".join(args[idx+1:]) if idx+1 < len(args) else None
            
            # Special handling for save service
            if service == "save":
                # Check for -d/--dialog option
                with_dialog = "-d" in args or "--dialog" in args
                return commands.restart_save(service, with_dialog)
            else:
                return commands.restart(service, custom_text, with_monitor, interval_minutes)
        
        elif command == "stop":
            service = "autoinput"
            with_monitor = False
            
            # Parse arguments
            remaining_args = []
            for arg in args:
                if arg in ["-m", "--monitor"]:
                    with_monitor = True
                else:
                    remaining_args.append(arg)
            
            if remaining_args:
                service = remaining_args[0]
            
            # Special handling for save service
            if service == "save":
                return commands.stop_save(service)
            else:
                return commands.stop(service, with_monitor)
        
        elif command == "test":
            service = args[0] if args else "autoinput"
            return commands.test(service)
        
        elif command == "exec":
            service = "autoinput"
            command_text = None
            
            # Parse arguments
            if "--" in args:
                idx = args.index("--")
                service = args[0] if idx > 0 else "autoinput"
                command_text = " ".join(args[idx+1:]) if idx+1 < len(args) else None
            
            return commands.exec(service, command_text)
        
        elif command == "list":
            return commands.list()
        
        else:
            print(f"❌ Unknown command: {command}")
            print("Use 'ccc help' for usage information")
            return 1
            
    except Exception as e:
        print(f"❌ Error: {e}")
        return 1

if __name__ == "__main__":
    sys.exit(main())