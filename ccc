def handle_context_command(args):
    """Handle context command with various subcommands"""
    from pathlib import Path

    # Add lib directory to path for imports
    sys.path.insert(0, str(Path(__file__).parent / "lib"))
    from ccc_manager import CCCManager
    from ccc_commands import Commands

    manager = CCCManager()
    commands = Commands(manager)

    if len(args) == 0:
        # Simple context read (own context)
        return commands.context_read()

    # Check for 'to' subcommand
    if args[0].lower() == "to":
        if len(args) < 2:
            print("❌ Missing target. Usage: ccc context to [Claude-2|Aider-1|Aider-2|all]")
            return 1

        target = args[1]

        # Check for message after --
        message = None
        if "--" in args:
            idx = args.index("--")
            if idx + 1 < len(args):
                message = " ".join(args[idx+1:])

        return commands.context_write(target, message)

    else:
        # Direct instance specification (e.g., ccc context cl2)
        ai_instance = args[0]
        return commands.context_read(ai_instance)

